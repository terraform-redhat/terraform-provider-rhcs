{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Schedule: routine PRs only on weekends. Schedule is ignored for GitHub Dependabot vulnerability PRs.",
  "extends": [
    "config:recommended"
  ],
  "commitMessagePrefix": "OCM-00000 | ",
  "prConcurrentLimit": 10,
  "prHourlyLimit": 0,
  "reviewersFromCodeOwners": true,
  "tekton": {
    "schedule": [
      "at any time"
    ]
  },
  "dependencyDashboard": true,
  "minimumReleaseAge": "3 days",
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "labels": [
    "ok-to-test"
  ],
  "packageRules": [
    {
      "description": "HashiCorp Terraform plugin stack",
      "groupName": "hashicorp-terraform",
      "matchManagers": [
        "gomod"
      ],
      "matchPackageNames": [
        "github.com/hashicorp/{/,}**"
      ]
    },
    {
      "description": "AWS SDK v2 and smithy",
      "groupName": "aws-sdk",
      "matchManagers": [
        "gomod"
      ],
      "matchPackageNames": [
        "github.com/aws/{/,}**"
      ]
    },
    {
      "description": "OpenShift OCM libraries",
      "groupName": "openshift-ocm",
      "matchManagers": [
        "gomod"
      ],
      "matchPackageNames": [
        "github.com/openshift-online/{/,}**"
      ]
    },
    {
      "description": "Kubernetes client libraries",
      "groupName": "kubernetes",
      "matchManagers": [
        "gomod"
      ],
      "matchPackageNames": [
        "k8s.io/{/,}**",
        "sigs.k8s.io/{/,}**"
      ]
    },
    {
      "description": "Test stack",
      "groupName": "testing",
      "matchManagers": [
        "gomod"
      ],
      "matchPackageNames": [
        "github.com/onsi/{/,}**",
        "go.uber.org/{/,}**"
      ]
    }
  ]
}
