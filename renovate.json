{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":gitSignOff"
  ],
  "dockerfile": {
    "managerFilePatterns": [
      "/^Dockerfile$/",
      "/^Dockerfile\\.clients$/",
      "/^build/ci-tf-e2e\\.Dockerfile$/"
    ]
  },
  "commitMessagePrefix": "OCM-00000 | ci: ",
  "prConcurrentLimit": 2,
  "prHourlyLimit": 0,
  "reviewersFromCodeOwners": true,
  "tekton": {
    "schedule": [
      "at any time"
    ]
  },
  "gomod": {
    "constraints": {
      "go": "1.26.5"
    },
    "postUpdateOptions": [
      "gomodUpdateImportPaths",
      "gomodTidy"
    ],
    "packageRules": [
      {
        "matchManagers": [
          "gomod"
        ],
        "matchDepTypes": [
          "indirect"
        ],
        "enabled": false
      }
    ]
  },
  "dependencyDashboard": true,
  "minimumReleaseAge": "3 days",
  "vulnerabilityAlerts": {
    "enabled": false
  },
  "customManagers": [
    {
      "description": "Update gci in Makefile",
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "GCI_VERSION \\?= (?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "go",
      "depNameTemplate": "github.com/daixiang0/gci"
    },
    {
      "description": "Update golangci-lint in Makefile",
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "GOLANGCI_LINT_VERSION \\?= (?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "go",
      "depNameTemplate": "github.com/golangci/golangci-lint/v2"
    },
    {
      "description": "Update addlicense in Makefile",
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "ADDLICENSE_VERSION \\?= (?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "go",
      "depNameTemplate": "github.com/google/addlicense"
    },
    {
      "description": "Update vale in Makefile",
      "customType": "regex",
      "managerFilePatterns": [
        "/^Makefile$/"
      ],
      "matchStrings": [
        "VALE_VERSION \\?= (?<currentValue>\\S+)"
      ],
      "datasourceTemplate": "go",
      "depNameTemplate": "github.com/errata-ai/vale/v3"
    }
  ],
  "pip_requirements": {
    "managerFilePatterns": [
      "/^build\\/ci-tf-e2e-requirements\\.txt$/"
    ]
  },
  "labels": [
    "ok-to-test"
  ],
  "packageRules": [
    {
      "description": "Enable automerge Konflux tekton task updates",
      "matchManagers": [
        "tekton"
      ],
      "automerge": true
    },
    {
      "description": "Do not bump Go toolchain minor/major versions",
      "matchManagers": [
        "gomod"
      ],
      "matchDatasources": [
        "golang-version"
      ],
      "matchDepTypes": [
        "toolchain"
      ],
      "matchUpdateTypes": [
        "minor",
        "major"
      ],
      "enabled": false
    },
    {
      "description": "CI client Dockerfile (UBI base, Terraform)",
      "matchManagers": [
        "dockerfile"
      ],
      "matchFileNames": [
        "Dockerfile.clients",
        "Dockerfile",
        "build/ci-tf-e2e.Dockerfile"
      ],
      "groupName": "CI client image",
      "groupSlug": "ci-client-image",
      "automerge": false
    },
    {
      "description": "HashiCorp Terraform plugin stack",
      "groupName": "hashicorp-terraform",
      "matchManagers": [
        "gomod"
      ],
      "matchPackageNames": [
        "github.com/hashicorp/{/,}**"
      ]
    },
    {
      "description": "AWS SDK v2 and smithy",
      "groupName": "aws-sdk",
      "matchManagers": [
        "gomod"
      ],
      "matchPackageNames": [
        "github.com/aws/{/,}**"
      ]
    },
    {
      "description": "OpenShift OCM libraries",
      "groupName": "openshift-ocm",
      "matchManagers": [
        "gomod"
      ],
      "matchPackageNames": [
        "github.com/openshift-online/{/,}**"
      ]
    },
    {
      "description": "Kubernetes client libraries",
      "groupName": "kubernetes",
      "matchManagers": [
        "gomod"
      ],
      "matchPackageNames": [
        "k8s.io/{/,}**",
        "sigs.k8s.io/{/,}**"
      ]
    },
    {
      "description": "Test stack",
      "groupName": "testing",
      "matchManagers": [
        "gomod"
      ],
      "matchPackageNames": [
        "github.com/onsi/{/,}**",
        "go.uber.org/{/,}**"
      ]
    },
    {
      "description": "Helpers libraries",
      "groupName": "helpers",
      "matchManagers": [
        "gomod"
      ],
      "matchPackageNames": [
        "github.com/Masterminds/semver",
        "github.com/pkg/errors",
        "github.com/segmentio/ksuid",
        "github.com/sirupsen/logrus",
        "github.com/thoas/go-funk",
        "github.com/zgalor/weberr",
        "gopkg.in/yaml.v2",
        "gopkg.in/yaml.v3"
      ]
    }
  ]
}
